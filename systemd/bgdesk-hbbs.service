
[Unit]
Description=BGDesk Signal Server

[Service]
Type=simple
LimitNOFILE=1000000
ExecStart=/usr/bin/hbbs
WorkingDirectory=/var/lib/bgdesk-server/
User=
Group=
Restart=always
StandardOutput=append:/var/log/bgdesk-server/hbbs.log
StandardError=append:/var/log/bgdesk-server/hbbs.error
# Restart service after 10 seconds if node service crashes
RestartSec=10

[Install]
WantedBy=multi-user.target

